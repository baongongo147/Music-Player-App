# Binary files
*.obj
*.exe
*.dll
*.lib
*.dylib
*.out
*.bin
 
# Build directories and files
# Generated by compilers like GCC, Clang, MSVC
# For Visual Studio:
[Dd]ebug/
[Rr]elease/
x64/
x86/
bin/
obj/
*.ilk
*.pdb
*.tlog
*.idb
*.ipch
*.log
 
# CMake build files and directories
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
install_manifest.txt
CTestTestfile.cmake
_CPack_Packages/
*.cmake.in
*.cmake
 
# Visual Studio (Windows) specific files and folders
.vs/                   # Hidden folder for VS solution info
*.VC.db
*.VC.opendb
*.vcxproj.user
*.vcxproj.filters
*.sln.opt
*.suo
*.user
ipch/                  # Precompiled header cache
*.aps                  # Resource compiler files
*.bsc                  # Browse information files
*.sbr                  # Source Browser files
*.manifest
*.vsp
*.sdf                  # Visual Studio SQL Server Compact Edition database file
*.opensdf              # Visual Studio SQL Server Compact Edition database file
*.cache
*.ncb
*.rcproj
 
# Visual Studio Code (VS Code) specific files
# Only ignore user-specific settings. You might want to keep launch.json or tasks.json.
.vscode/*.code-workspace
.vscode/*.jsonc
.vscode/*.bak
.vscode/*.log
.vscode/tasks.json     # Consider if you want to share common tasks
.vscode/settings.json  # Consider if you want to share common settings
.vscode/launch.json    # Consider if you want to share common debug configurations
 
# JetBrains IDEs (CLion, etc.)
.idea/                 # Directory for IntelliJ-based IDE settings
*.iml
*.iws
*.ipr
cmake-build-*/         # Default build directory for CLion
 
# Eclipse IDE files
.project
.cproject
.settings/
 
# Xcode (macOS) specific files
*.xcodeproj/xcuserdata/ # User-specific data for Xcode projects
DerivedData/
*.xcuserstate
*.mode1v3
*.pbxuser
*.perspectivev3
*.xcworkspace/xcuserdata/
*.xcworkspacedata
*.hmap
 
# macOS specific files
.DS_Store
.AppleDouble
.LSOverride
 
# Windows specific files
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
 
# Temporary files, backups, and logs
*~
*.bak
*.tmp
*.log
*.swp
*.swo
*.swn
*#
 
# Doxygen generated documentation
html/
latex/
 
# Package management (e.g., vcpkg)
vcpkg_installed/
